---
interface Props {
  variant?: 'cyan' | 'violet';
  text: string;
}

const { variant = 'cyan', text } = Astro.props;
---

<div class={`label-tag ${variant}`}>
  <span class="label-dot"></span>
  {text}
</div>

<style>
  .label-tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 13px;
    border-radius: 999px;
    margin-bottom: 18px;
  }

  .label-tag.cyan {
    color: var(--cyan);
    background: rgba(6, 182, 212, 0.07);
    border: 1px solid rgba(6, 182, 212, 0.2);
  }

  .label-tag.violet {
    color: var(--violet);
    background: rgba(139, 92, 246, 0.07);
    border: 1px solid rgba(139, 92, 246, 0.2);
  }

  .label-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
  }
</style>
