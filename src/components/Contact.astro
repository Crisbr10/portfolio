---
import SectionLabel from './SectionLabel.astro';

const linkedinSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>`;

const githubSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`;
---

<section id="contact">
  <div class="container">
    <div class="fade-up">
      <SectionLabel variant="cyan" text="Contacto" />
      <h2 class="section-title">
        Charlemos
      </h2>
      <p class="contact-intro">
        ¿Tienes algo en mente? Escríbeme sin compromiso y lo conversamos.
      </p>
    </div>

    <form class="contact-form fade-up delay-1" id="contactForm">
      <!-- Honeypot — hidden from real users, traps bots -->
      <div class="hp-field" aria-hidden="true">
        <input name="website" type="text" autocomplete="off" tabindex="-1" />
      </div>
      <div class="form-row">
        <div class="field">
          <label for="name">Nombre</label>
          <input id="name" name="name" type="text" placeholder="Tu nombre" required />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" placeholder="tu@email.com" required />
        </div>
      </div>
      <div class="field">
        <label for="message">Mensaje</label>
        <textarea id="message" name="message" placeholder="Contame qué tienes en mente..." required minlength="10"></textarea>
      </div>
      <button type="submit" class="form-submit" id="submitBtn">Enviar Mensaje →</button>
      <div class="form-message" id="formMessage"></div>
    </form>

    <div class="contact-links fade-up delay-2">
      <a href="#" class="contact-link" aria-label="LinkedIn">
        <Fragment set:html={linkedinSvg} />
        LinkedIn
      </a>
      <a href="#" class="contact-link" aria-label="GitHub">
        <Fragment set:html={githubSvg} />
        GitHub
      </a>
    </div>
  </div>
</section>

<script>
  // Capture page load timestamp for timing check
  const tLoad = Date.now();

  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  const btn = document.getElementById('submitBtn') as HTMLButtonElement | null;
  const msgEl = document.getElementById('formMessage') as HTMLDivElement | null;

  if (form && btn && msgEl) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Gather values
      const name = (form.elements.namedItem('name') as HTMLInputElement).value.trim();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      const message = (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim();
      const website = (form.elements.namedItem('website') as HTMLInputElement).value;

      // Loading state
      const originalText = btn.textContent;
      btn.textContent = 'Enviando...';
      btn.disabled = true;
      btn.style.opacity = '0.7';
      btn.style.cursor = 'wait';
      msgEl.textContent = '';
      msgEl.className = 'form-message';

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, email, message, website, t_load: tLoad }),
        });

        const data = await res.json();

        if (res.ok && data.success) {
          // Success state
          btn.textContent = '✓ Mensaje enviado';
          btn.style.background = '#059669';
          btn.style.opacity = '';
          btn.style.cursor = '';
          msgEl.textContent = '¡Gracias! Tu mensaje fue enviado correctamente.';
          msgEl.className = 'form-message form-success';
          form.reset();

          setTimeout(() => {
            btn.textContent = originalText;
            btn.style.background = '';
            btn.disabled = false;
            msgEl.textContent = '';
            msgEl.className = 'form-message';
          }, 3000);
        } else {
          // Error state from server
          const errorMsg = data.error || 'Ocurrió un error. Intenta de nuevo.';
          msgEl.textContent = errorMsg;
          msgEl.className = 'form-message form-error';
          btn.textContent = originalText;
          btn.disabled = false;
          btn.style.opacity = '';
          btn.style.cursor = '';
        }
      } catch (err) {
        // Network error
        console.error('Contact form error:', err);
        msgEl.textContent = 'Error de conexión. Intenta de nuevo.';
        msgEl.className = 'form-message form-error';
        btn.textContent = originalText;
        btn.disabled = false;
        btn.style.opacity = '';
        btn.style.cursor = '';
      }
    });
  }
</script>

<style>
  #contact {
    padding: 120px 0 60px;
  }

  #contact .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact-intro {
    font-size: 15px;
    color: var(--text-muted);
    max-width: 460px;
    line-height: 1.75;
    margin-bottom: 52px;
  }

  .contact-form {
    width: 100%;
    max-width: 540px;
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px 40px 36px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 14px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 14px;
  }

  .field label {
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: left;
  }

  .field input,
  .field textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 11px 14px;
    color: var(--text);
    font-family: var(--font);
    font-size: 13.5px;
    outline: none;
    resize: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--text-dim);
  }

  .field input:focus,
  .field textarea:focus {
    border-color: rgba(6, 182, 212, 0.45);
    box-shadow: 0 0 0 3px rgba(6, 182, 212, 0.07);
  }

  .field textarea { min-height: 112px; }

  .form-submit {
    width: 100%;
    padding: 13px;
    border-radius: 8px;
    background: var(--cyan);
    color: #040810;
    font-family: var(--font);
    font-size: 14px;
    font-weight: 600;
    border: none;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .form-submit:hover {
    box-shadow: 0 0 32px rgba(6, 182, 212, 0.45);
    transform: translateY(-1px);
  }

  .form-submit:disabled {
    cursor: wait;
    transform: none;
  }

  /* Honeypot — display:none to hide from users and screen readers */
  .hp-field {
    display: none;
  }

  /* Form feedback messages */
  .form-message {
    margin-top: 14px;
    font-size: 13px;
    text-align: center;
    min-height: 0;
    transition: opacity 0.3s;
  }

  .form-success {
    color: #34d399;
  }

  .form-error {
    color: #f87171;
  }

  .contact-links {
    display: flex;
    gap: 16px;
    margin-top: 28px;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .contact-link:hover {
    border-color: rgba(6, 182, 212, 0.35);
    color: var(--cyan);
    background: var(--cyan-dim);
  }
</style>
