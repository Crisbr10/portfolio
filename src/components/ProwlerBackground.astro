---
// Prowler-style background:
// large tile grid + two angled light beams from bottom corners
---

<div class="prowler-bg">
  <div class="prowler-grid"></div>
  <div class="beam-left"></div>
  <div class="beam-right"></div>
  <div class="vignette"></div>
</div>

<style>
  .prowler-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Large tile grid */
  .prowler-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  /* Cyan beam — bottom-left corner */
  .beam-left {
    position: absolute;
    bottom: -10%;
    left: -5%;
    width: 55%;
    height: 85%;
    background: radial-gradient(
      ellipse at 20% 100%,
      rgba(6, 182, 212, 0.22) 0%,
      rgba(6, 182, 212, 0.08) 35%,
      transparent 70%
    );
    filter: blur(8px);
  }

  /* Violet beam — bottom-right corner */
  .beam-right {
    position: absolute;
    bottom: -10%;
    right: -5%;
    width: 55%;
    height: 85%;
    background: radial-gradient(
      ellipse at 80% 100%,
      rgba(139, 92, 246, 0.18) 0%,
      rgba(139, 92, 246, 0.06) 35%,
      transparent 70%
    );
    filter: blur(8px);
  }

  /* Center vignette */
  .vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(7, 11, 20, 0.92) 0%, transparent 100%),
      radial-gradient(ellipse 60% 40% at 50% 50%, rgba(7, 11, 20, 0.5) 0%, transparent 100%);
  }
</style>
