---
import {
  Terminal, LayoutDashboard, Database, Sparkles,
  Layers, GitBranch, Rocket, Atom, FileCode2, Wind, Smartphone,
  Zap, Code2, Cylinder, Server,
  Bot, TerminalSquare, FlaskConical, TestTubeDiagonal, Box, Send,
} from 'lucide-astro';
import SectionLabel from './SectionLabel.astro';

const categories = [
  {
    name: 'Low-Code & Automatización',
    headerIcon: Terminal,
    headerVariant: 'cyan' as const,
    count: '02',
    chipVariant: 'cyan' as const,
    tools: [
      { icon: Layers, label: 'Velneo' },
      { icon: GitBranch, label: 'N8N' },
    ],
  },
  {
    name: 'Frontend & Móvil',
    headerIcon: LayoutDashboard,
    headerVariant: 'violet' as const,
    count: '05',
    chipVariant: 'violet' as const,
    tools: [
      { icon: Rocket, label: 'Astro' },
      { icon: Atom, label: 'React' },
      { icon: FileCode2, label: 'TypeScript' },
      { icon: Wind, label: 'Tailwind' },
      { icon: Smartphone, label: 'React Native' },
    ],
  },
  {
    name: 'Backend & Datos',
    headerIcon: Database,
    headerVariant: 'cyan' as const,
    count: '04',
    chipVariant: 'cyan' as const,
    tools: [
      { icon: Zap, label: 'FastAPI' },
      { icon: Code2, label: 'Python' },
      { icon: Cylinder, label: 'PostgreSQL' },
      { icon: Server, label: 'Supabase' },
    ],
  },
  {
    name: 'Agéntico & Calidad',
    headerIcon: Sparkles,
    headerVariant: 'violet' as const,
    count: '07',
    chipVariant: 'violet' as const,
    tools: [
      { icon: Bot, label: 'Claude Code' },
      { icon: TerminalSquare, label: 'Open Code' },
      { icon: FlaskConical, label: 'Vitest' },
      { icon: TestTubeDiagonal, label: 'Jest' },
      { icon: GitBranch, label: 'GH Actions' },
      { icon: Box, label: 'Docker' },
      { icon: Send, label: 'Resend' },
    ],
  },
];
---

<section id="tools">
  <div class="container">
    <div class="fade-up">
      <SectionLabel variant="violet" text="Stack Técnico" />
      <h2 class="section-title">Herramientas &amp; Tecnologías</h2>
      <p class="section-sub">
        Herramientas cuidadosamente seleccionadas para construir productos de
        calidad, desde el prototipo hasta producción.
      </p>
    </div>

    <div class="tools-grid fade-up">
      {categories.map((cat) => {
        const HeaderIcon = cat.headerIcon;
        return (
          <div class="tools-cat">
            <div class="tools-cat-hd">
              <div class={`tools-cat-icon-wrap ${cat.headerVariant}`}>
                <HeaderIcon size={16} strokeWidth={1.5} />
              </div>
              <span class="tools-cat-name">{cat.name}</span>
              <span class="tools-cat-count">{cat.count}</span>
            </div>

            <div class="tools-icons-grid">
              {cat.tools.map((tool) => {
                const ToolIcon = tool.icon;
                return (
                  <div class={`tool-icon-item ${cat.chipVariant}`}>
                    <ToolIcon size={26} strokeWidth={1.4} />
                    <span class="tool-label">{tool.label}</span>
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  #tools {
    padding: 120px 0;
  }

  #tools .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  #tools :global(.section-sub) { margin-bottom: 64px; }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    width: 100%;
  }

  .tools-cat {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 32px 32px 28px;
    text-align: left;
    transition: border-color 0.3s;
  }

  .tools-cat:hover { border-color: rgba(255, 255, 255, 0.1); }

  .tools-cat-hd {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .tools-cat-icon-wrap {
    width: 34px; height: 34px;
    border-radius: 9px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tools-cat-icon-wrap.cyan {
    background: var(--cyan-dim);
    color: var(--cyan);
  }

  .tools-cat-icon-wrap.violet {
    background: var(--violet-dim);
    color: var(--violet);
  }

  .tools-cat-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .tools-cat-count {
    margin-left: auto;
    font-family: var(--mono);
    font-size: 10.5px;
    color: var(--text-dim);
    letter-spacing: 0.06em;
  }

  .tools-icons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 12px;
  }

  .tool-icon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 14px 8px 12px;
    border-radius: 10px;
    border: 1px solid transparent;
    cursor: default;
    color: var(--text-dim);
    transition: border-color 0.22s, background 0.22s, box-shadow 0.22s, color 0.22s;
  }

  .tool-icon-item.cyan:hover {
    border-color: rgba(6, 182, 212, 0.3);
    background: rgba(6, 182, 212, 0.05);
    box-shadow: 0 0 18px rgba(6, 182, 212, 0.08);
    color: var(--cyan);
  }

  .tool-icon-item.violet:hover {
    border-color: rgba(139, 92, 246, 0.3);
    background: rgba(139, 92, 246, 0.05);
    box-shadow: 0 0 18px rgba(139, 92, 246, 0.08);
    color: var(--violet);
  }

  .tool-label {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.02em;
    text-align: center;
    line-height: 1.3;
  }
</style>
