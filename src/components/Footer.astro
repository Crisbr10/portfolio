---
const year = new Date().getFullYear();
---

<footer>
  <p class="footer-copy">Cristhian Borges © {year}</p>
</footer>

<style>
  footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 24px 56px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .footer-copy {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }
</style>
